# FinanceAI Backend Environment Variables

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_database_password
DB_NAME=fia

# JWT Secret
JWT_SECRET_KEY=change-this-to-a-secure-random-secret-key

# OpenRouter AI
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=google/gemini-2.5-flash

# Newsletter email notification
# Use a Gmail App Password or SMTP credentials from your mail provider.
NEWSLETTER_NOTIFY_EMAIL=your_admin_email@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_email@example.com
SMTP_PASSWORD=your_smtp_app_password
SMTP_FROM_EMAIL=your_smtp_email@example.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Flask
PORT=5000
FRONTEND_URL=http://localhost:5173
